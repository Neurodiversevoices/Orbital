{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "production": {
      "distribution": "store",
      "cache": {
        "key": "orbital-ios-{{ checksum \"package-lock.json\" }}",
        "paths": [
          "node_modules",
          ".expo"
        ]
      },
      "ios": {
        "credentialsSource": "remote",
        "autoIncrement": "buildNumber",
        "resourceClass": "m-medium"
      },
      "android": {
        "credentialsSource": "remote",
        "buildType": "app-bundle",
        "autoIncrement": "versionCode"
      },
      "env": {
        "EXPO_PUBLIC_IS_REVIEW_MODE": "true",
        "SENTRY_ALLOW_FAILURE": "true"
      }
    },
    "review": {
      "distribution": "store",
      "ios": {
        "credentialsSource": "remote",
        "autoIncrement": "buildNumber",
        "resourceClass": "m-medium"
      },
      "android": {
        "credentialsSource": "remote",
        "buildType": "app-bundle",
        "autoIncrement": "versionCode"
      },
      "env": {
        "EXPO_PUBLIC_APP_STORE_REVIEW": "1",
        "SENTRY_ALLOW_FAILURE": "true"
      }
    },
    "founder-demo": {
      "distribution": "internal",
      "ios": {
        "credentialsSource": "remote",
        "resourceClass": "m-medium"
      },
      "android": {
        "credentialsSource": "remote",
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_FOUNDER_DEMO": "1",
        "SENTRY_ALLOW_FAILURE": "true"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6757295146",
        "ascApiKeyId": "K5FGNKXMAZ",
        "ascApiKeyIssuerId": "a6c8bd6a-8f60-4aed-a0a6-d129cb2aaf7a",
        "ascApiKeyPath": "./keys/AuthKey_K5FGNKXMAZ.p8"
      },
      "android": {
        "serviceAccountKeyPath": "./keys/google-play-service-account.json",
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  }
}
