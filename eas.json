{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "production": {
      "distribution": "store",
      "ios": {
        "credentialsSource": "remote",
        "autoIncrement": "buildNumber",
        "resourceClass": "m-medium"
      },
      "android": {
        "credentialsSource": "remote",
        "buildType": "app-bundle",
        "autoIncrement": "versionCode"
      },
      "env": {
        "EXPO_PUBLIC_IS_REVIEW_MODE": "true",
        "EXPO_PUBLIC_PAYMENTS_ENABLED": "true",
        "SENTRY_ALLOW_FAILURE": "true",
        "EAS_USE_CACHE": "0"
      }
    },
    "review": {
      "distribution": "store",
      "ios": {
        "credentialsSource": "remote",
        "autoIncrement": "buildNumber",
        "resourceClass": "m-medium"
      },
      "android": {
        "credentialsSource": "remote",
        "buildType": "app-bundle",
        "autoIncrement": "versionCode"
      },
      "env": {
        "EXPO_PUBLIC_APP_STORE_REVIEW": "1",
        "SENTRY_ALLOW_FAILURE": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "credentialsSource": "remote",
        "resourceClass": "m-medium"
      },
      "android": {
        "credentialsSource": "remote",
        "buildType": "apk"
      },
      "env": {
        "SENTRY_ALLOW_FAILURE": "true"
      }
    },
    "founder-demo": {
      "distribution": "internal",
      "ios": {
        "credentialsSource": "remote",
        "resourceClass": "m-medium"
      },
      "android": {
        "credentialsSource": "remote",
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_FOUNDER_DEMO": "1",
        "SENTRY_ALLOW_FAILURE": "true"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6757295146",
        "ascApiKeyId": "HD4HWHHYDK",
        "ascApiKeyIssuerId": "a6c8bd6a-8f60-4aed-a0a6-d129cb2aaf7a",
        "ascApiKeyPath": "./keys/AuthKey_HD4HWHHYDK.p8"
      },
      "android": {
        "serviceAccountKeyPath": "./keys/google-play-service-account.json",
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  }
}
