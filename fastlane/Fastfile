require "fileutils"
require "shellwords"

error do |lane, exception|
  error_message = <<~MSG
    🚨 ORBITAL RELEASE FAILURE
    Lane: #{lane}
    Error: #{exception.message}
    Time: #{Time.now}

    Fix the error and re-run:
    bundle exec fastlane #{lane}
  MSG

  UI.error(error_message)
  FileUtils.mkdir_p("./fastlane/logs")
  File.write("./fastlane/logs/last_error.txt", error_message)
  system("osascript", "-e", "display notification \"#{lane} failed\" with title \"Orbital Release Failed\"")
end

default_platform(:ios)

# App Store Connect API key (same as eas.json submit.production.ios)
def orbital_asc_api_key
  app_store_connect_api_key(
    key_id: "HD4HWHHYDK",
    issuer_id: "a6c8bd6a-8f60-4aed-a0a6-d129cb2aaf7a",
    key_filepath: File.expand_path("../keys/AuthKey_HD4HWHHYDK.p8", File.dirname(__FILE__))
  )
end

platform :ios do

  desc "Typecheck + repo sanity before release"
  lane :pre_submit_checks do
    sh("npm run typecheck")
  end

  desc "Run Maestro smoke tests (blocks release on failure)"
  lane :maestro_smoke do
    UI.message("Running Maestro smoke tests...")
    sh("mkdir -p ./fastlane/logs")
    sh(
      "maestro test ./maestro/tests/smoke_test.yaml " \
      "--format junit " \
      "--output ./fastlane/logs/test_results.xml"
    )
    UI.success("All smoke tests passed!")
  end

  desc "Publish EAS Update OTA to a channel"
  lane :publish_ota do |options|
    channel = options[:channel] || "production"
    UI.message("Publishing OTA to #{channel}...")
    sh("./scripts/ota-publish.sh #{channel}")
    UI.success("OTA published!")
  end

  desc "Rollback production OTA to previous revision"
  lane :rollback_ota do
    UI.important("Rolling back OTA update...")
    sh("./scripts/ota-rollback.sh")
    UI.success("OTA rolled back!")
  end

  desc "Staged OTA rollout (percentage 1–100)"
  lane :staged_ota do |options|
    pct = options[:percentage] || 10
    UI.message("Staged OTA rollout: #{pct}%")
    sh("./scripts/ota-staged.sh #{pct}")
  end

  desc "Weekly health checks"
  lane :health_check do
    UI.message("Running weekly health checks...")
    sh("./scripts/health-check.sh")
    UI.success("Health check complete!")
  end

  desc "Performance check (Maestro smoke duration)"
  lane :check_performance do
    UI.message("Running performance checks...")
    sh("./scripts/perf-check.sh")
    UI.success("Performance check passed!")
  end

  desc "Crash stress (Maestro navigation + resume)"
  lane :crash_detection do
    UI.message("Running crash detection...")
    sh("mkdir -p ./fastlane/logs")
    sh(
      "maestro test ./maestro/tests/crash_test.yaml " \
      "--format junit " \
      "--output ./fastlane/logs/crash_results.xml"
    )
    UI.success("No crashes detected!")
  end

  desc "Generate App Store release notes from git history"
  lane :generate_release_notes do
    UI.message("Generating release notes...")
    sh("./scripts/generate-release-notes.sh")
    UI.success("Release notes ready!")
  end

  desc "Validate IAP configuration (manual checklist in ASC / RevenueCat)"
  lane :validate_iap do
    UI.message("Validate IAP: App Store Connect products + RevenueCat offerings match app code.")
  end

  desc "Upload IAP review screenshots (manual / asc-mcp for non-subscription IAPs)"
  lane :upload_iap_screenshots do
    UI.important("Upload subscription/CCI review screenshots in App Store Connect (see APP_STORE_METADATA.md).")
  end

  desc "Upload App Store metadata (Fastlane metadata folder)"
  lane :upload_metadata do
    upload_to_app_store(
      app_identifier: "com.erparris.orbital",
      api_key: orbital_asc_api_key,
      force: true,
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: true,
      metadata_path: "./fastlane/metadata"
    )
  end

  desc "Post-release reminders (ASC review timing)"
  lane :post_release_check do
    UI.message("Running post-release checks...")
    sh("echo 'Checking ASC build status...'")
    UI.success("Post-release check complete!")
    UI.message("Check App Store Connect in ~1 hour")
    UI.message("Review typically takes ~24 hours")
  end

  desc "Single-command iOS release (local / CI)"
  lane :release_ios do
    pre_submit_checks
    maestro_smoke
    check_performance
    crash_detection
    validate_iap
    generate_release_notes
    screenshots
    upload_screenshots
    upload_iap_screenshots
    upload_metadata
    build_production
    submit
    post_release_check
  end

  desc "Capture App Store screenshots (Maestro smoke test → fastlane/screenshots/en-US)"
  desc "Note: `fastlane snapshot` (UI test) is not configured; this lane is the supported pipeline."
  lane :screenshots do
    script = File.expand_path("../scripts/app-store-screenshots.sh", __dir__)
    FileUtils.chmod(0o755, script)
    sh(Shellwords.join(["/bin/bash", script]))
  end

  desc "Upload screenshots to App Store Connect"
  lane :upload_screenshots do
    upload_to_app_store(
      app_identifier: "com.erparris.orbital",
      api_key: orbital_asc_api_key,
      force: true,
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: false,
      screenshots_path: "./fastlane/screenshots"
    )
  end

  desc "Full screenshot pipeline"
  lane :refresh_screenshots do
    screenshots
    upload_screenshots
  end

  desc "Build production IPA"
  lane :build_production do
    build_app(
      workspace: "./ios/Orbital.xcworkspace",
      scheme: "Orbital",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "Orbital.ipa"
    )
  end

  desc "Submit to App Store"
  lane :submit do
    upload_to_app_store(
      app_identifier: "com.erparris.orbital",
      api_key: orbital_asc_api_key,
      ipa: "./build/Orbital.ipa",
      submit_for_review: true,
      automatic_release: false,
      skip_screenshots: true,
      skip_metadata: true
    )
  end

  desc "Upload screenshots only (same as: deliver run --skip_binary_upload --skip_metadata --force)"
  lane :deliver_screenshots do
    upload_to_app_store(
      app_identifier: "com.erparris.orbital",
      api_key: orbital_asc_api_key,
      force: true,
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: false,
      screenshots_path: "./fastlane/screenshots"
    )
  end

  desc "Maestro flow on iPad Pro 12.9 sim (when installed)"
  lane :ipad_screenshots do
    sh("xcrun simctl boot 'iPad Pro (12.9-inch) (6th generation)' 2>/dev/null || true")
    sh("maestro test ./maestro/tests/ipad_test.yaml")
  end

end
